{
  "name": "{{ cookiecutter.project_slug }}",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    {% if cookiecutter.sass_bootstrap == "enabled" -%}
    "bootstrap": "^5.1.1",
    "bootstrap-icons": "^1.13.1",
    {%- endif %}
    {% if cookiecutter.django_react == "enabled" -%}
    "django-react-loader": "^0.1.7",
    "nwb": "^0.24.7",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "webpack-bundle-tracker": "^0.4.3",
    "@babel/plugin-transform-react-jsx": "~7.16.7",
    {%- endif %}
    {% if cookiecutter.vue == "enabled" -%}
    "@uppy/aws-s3": "^5.1.0",
    "@uppy/core": "^5.2.0",
    "@uppy/dashboard": "^5.1.0",
    "@uppy/vue": "^3.1.0",
    "@uppy/xhr-upload": "^5.1.1",
    "@vitejs/plugin-vue": "^6.0.3",
    "humanize-plus": "^1.8.2",
    "glob": "^11.0.0",
    "rollup-plugin-external-globals": "^0.13.0",
    "vite": "^7.3.1",
    "vue": "^3.5.27"
    {%- endif %}
  },
  {% if cookiecutter.django_react == "enabled" -%}
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"{% if cookiecutter.vue == "enabled" %},
    "vue-dev": "vite build --watch --mode development",
    "vue-build": "vite build",
    "vue-preview": "vite preview"{% endif %}
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  {%- elif cookiecutter.vue == "enabled" -%}
  "scripts": {
    "vue-dev": "vite build --watch --mode development",
    "vue-build": "vite build",
    "vue-preview": "vite preview"
  },
  {%- endif -%}
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }{% if cookiecutter.vue == "enabled" %},
  "devDependencies": {
    "@vue/language-server": "^3.2.5",
    "@vue/typescript-plugin": "^3.2.5",
    "typescript-language-server": "^5.1.3"
  }{% endif %}
}
